---
import BaseLayout from "../layouts/BaseLayout.astro";
import vpsEU from "../data/vps_eu.json";
import proxyUS from "../data/proxy_us.json";

const baseUrl = import.meta.env.BASE_URL;
const countries = Array.from(new Set(vpsEU.map((x) => x.country))).sort();
const ipv4Modes = [
	"Любой",
	"IPv4 явно указан",
	"IPv4 не видно до заказа",
	"IPv4 не указано/не видно",
];
const availabilityModes = ["Любая", "В наличии/неизвестно", "Sold out / Out of stock"];
---

<BaseLayout title="Таблицы — VPS (EU) и Proxy (US)">
	<section class="card">
		<div class="card__inner">
			<h1 style="margin:0 0 6px;">Таблицы</h1>
			<p style="margin:0;" class="muted">
				Быстрый обзор: фильтры, поиск, заметки. Источник данных — ваши Markdown‑документы.
			</p>
		</div>
	</section>

	<section class="card" style="margin-top:16px;">
		<div class="card__inner">
			<div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center; justify-content:space-between;">
				<div style="display:flex; gap:10px; flex-wrap:wrap;">
					<button class="nav__link is-active" id="tab-vps" type="button">VPS (EU)</button>
					<button class="nav__link" id="tab-proxy" type="button">Proxy (US)</button>
				</div>
				<div class="mini">Подсказка: клик по названию провайдера открывает первоисточник.</div>
			</div>

			<div id="panel-vps" style="margin-top:14px;">
				<div class="toolbar">
					<div class="controls">
						<div class="field">
							<label for="q">Поиск</label>
							<input class="input" id="q" placeholder="провайдер, город, заметка…" />
						</div>
						<div class="field">
							<label for="country">Страна</label>
							<select class="select" id="country">
								<option value="ALL">Все</option>
								{countries.map((c) => <option value={c}>{c}</option>)}
							</select>
						</div>
						<div class="field">
							<label for="ipv4">IPv4</label>
							<select class="select" id="ipv4">
								{ipv4Modes.map((m) => <option value={m}>{m}</option>)}
							</select>
						</div>
						<div class="field">
							<label for="avail">Наличие</label>
							<select class="select" id="avail">
								{availabilityModes.map((m) => <option value={m}>{m}</option>)}
							</select>
						</div>
					</div>
					<div class="kpi">
						<span class="pill"><span class="dot"></span><strong id="count">0</strong><span class="muted">позиций</span></span>
					</div>
				</div>

				<div class="table-scroll">
					<table class="dataTable">
						<thead>
							<tr>
								<th>#</th>
								<th>Локация</th>
								<th>Провайдер</th>
								<th>План</th>
								<th>IPv4</th>
								<th>Цена</th>
								<th>Статус</th>
								<th>Заметка</th>
							</tr>
						</thead>
						<tbody id="rows">
							{vpsEU.map((x) => (
								<tr
									data-country={x.country}
									data-provider={x.provider}
									data-city={x.city}
									data-ipv4={x.ipv4}
									data-availability={x.availability}
									data-text={`${x.country} ${x.city} ${x.provider} ${x.plan} ${x.ipv4} ${x.price} ${x.notes}`.toLowerCase()}
								>
									<td class="cell-muted">{x.id}</td>
									<td>
										<span class="badge">{x.country}</span>
										<span class="mini" style="margin-left:8px;">{x.city}</span>
									</td>
									<td>
										<a href={x.url} target="_blank" rel="noreferrer">{x.provider}</a>
									</td>
									<td>{x.plan}</td>
									<td>{x.ipv4}</td>
									<td class="nowrap">{x.price}</td>
									<td>
										{x.availability === "sold_out" || x.availability === "out_of_stock" ? (
											<span class="badge badge--warn">нет слотов</span>
										) : x.availability === "unknown" ? (
											<span class="badge">неизвестно</span>
										) : (
											<span class="badge badge--ok">ok</span>
										)}
									</td>
									<td class="cell-note">{x.notes}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>

				<p class="mini" style="margin:12px 0 0;">
					Оригинальный документ: <a href={`${baseUrl}vps-eu/`}>VPS (EU)</a>
				</p>
			</div>

			<div id="panel-proxy" style="margin-top:14px; display:none;">
				<div class="table-scroll">
					<table class="dataTable">
						<thead>
							<tr>
								<th>#</th>
								<th>Категория</th>
								<th>Провайдер</th>
								<th>Тип IP</th>
								<th>Протоколы</th>
								<th>Цена</th>
								<th>Pay‑as‑you‑go</th>
								<th>Заметка</th>
							</tr>
						</thead>
						<tbody>
							{proxyUS.map((x) => (
								<tr>
									<td class="cell-muted">{x.id}</td>
									<td><span class="badge">{x.category}</span></td>
									<td><a href={x.url} target="_blank" rel="noreferrer">{x.provider}</a></td>
									<td>{x.ipType}</td>
									<td>{x.protocols}</td>
									<td class="nowrap">{x.pricing}</td>
									<td>{x.payg}</td>
									<td class="cell-note">{x.notes}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>

				<p class="mini" style="margin:12px 0 0;">
					Оригинальный документ: <a href={`${baseUrl}proxy-us/`}>Proxy (US)</a>
				</p>
			</div>
		</div>
	</section>

	<script is:inline>
		const $ = (sel) => document.querySelector(sel);
		const rows = Array.from(document.querySelectorAll("#rows tr"));
		const q = $("#q");
		const country = $("#country");
		const ipv4 = $("#ipv4");
		const avail = $("#avail");
		const count = $("#count");

		const tabVps = $("#tab-vps");
		const tabProxy = $("#tab-proxy");
		const panelVps = $("#panel-vps");
		const panelProxy = $("#panel-proxy");

		function normalizeMode(mode) {
			if (mode === "IPv4 явно указан") return "explicit";
			if (mode === "IPv4 не видно до заказа") return "hidden";
			if (mode === "IPv4 не указано/не видно") return "unknown";
			return "any";
		}

		function classifyIPv4(text) {
			const t = (text || "").toLowerCase();
			if (t.includes("ipv4: 1") || t.includes("1 ipv4") || t.includes("включены") && t.includes("ipv4")) return "explicit";
			if (t.includes("не видно")) return "hidden";
			return "unknown";
		}

		function availOk(mode, value) {
			if (mode === "Любая") return true;
			const isBad = value === "sold_out" || value === "out_of_stock";
			if (mode === "Sold out / Out of stock") return isBad;
			return !isBad; // "В наличии/неизвестно"
		}

		function applyFilters() {
			const query = (q.value || "").trim().toLowerCase();
			const c = country.value;
			const ipv4Mode = normalizeMode(ipv4.value);
			const availMode = avail.value;

			let visible = 0;
			for (const r of rows) {
				const text = r.dataset.text || "";
				const okQ = !query || text.includes(query);
				const okC = c === "ALL" || r.dataset.country === c;
				const okA = availOk(availMode, r.dataset.availability);

				const ipv4Class = classifyIPv4(r.dataset.ipv4);
				const okI = ipv4Mode === "any" || ipv4Class === ipv4Mode;

				const ok = okQ && okC && okI && okA;
				r.style.display = ok ? "" : "none";
				if (ok) visible++;
			}
			count.textContent = String(visible);
		}

		[q, country, ipv4, avail].forEach((el) => el.addEventListener("input", applyFilters));
		applyFilters();

		function setTab(name) {
			const isVps = name === "vps";
			panelVps.style.display = isVps ? "" : "none";
			panelProxy.style.display = isVps ? "none" : "";
			tabVps.classList.toggle("is-active", isVps);
			tabProxy.classList.toggle("is-active", !isVps);
		}

		tabVps.addEventListener("click", () => setTab("vps"));
		tabProxy.addEventListener("click", () => setTab("proxy"));
	</script>
</BaseLayout>
