---
import BaseLayout from "../layouts/BaseLayout.astro";
const baseUrl = import.meta.env.BASE_URL;
---
<BaseLayout title="vps-proxy-research — архив заметок">
	<section class="card">
		<div class="card__inner">
			<div class="grid">
				<div>
					<h1>Чтобы не потерялось.</h1>
					<p>
						Этот сайт — статический архив ваших Obsidian‑заметок с акцентом на практику:
						провайдеры, цены, IPv4/IPv6, риски, и что проверять в тесте.
					</p>

					<div style="display:flex; flex-wrap:wrap; gap:10px; margin-top:14px;">
						<span class="pill"><span class="dot"></span> VPS (EU): подбор под SSH</span>
						<span class="pill"><span class="dot dot--blue"></span> Proxy (US): точка выхода</span>
						<span class="pill">таблицы + фильтры</span>
					</div>

					<div style="display:flex; flex-wrap:wrap; gap:10px; margin-top:16px;">
						<a class="btn btn--primary" href={`${baseUrl}tables/`}>Открыть таблицы</a>
						<a class="btn" href={`${baseUrl}vps-eu/`}>Читать VPS (EU)</a>
						<a class="btn" href={`${baseUrl}proxy-us/`}>Читать Proxy (US)</a>
					</div>
				</div>

				<aside class="card" style="box-shadow:none; background: var(--card2);">
					<div class="card__inner">
						<h3 style="margin-top:0;">Как пользоваться</h3>
						<ul style="margin:0; padding-left: 18px; color: var(--muted);">
							<li>начните с <a href={`${baseUrl}tables/`}>таблиц</a> и отфильтруйте “что реально видно на странице”</li>
							<li>откройте полный документ, чтобы увидеть нюансы и вопросы в пресейл</li>
							<li>фиксируйте результат теста прямо в Obsidian и обновляйте Markdown</li>
						</ul>
						<p class="mini" style="margin-top:12px;">
							Сайт не требует серверной части и подходит для GitHub Pages.
						</p>
					</div>
				</aside>
			</div>
		</div>
	</section>
</BaseLayout>
