---
import "../styles/global.css";

const {
	title = "vps-proxy-research",
	description = "Архив заметок: VPS (EU) и Proxy (US) — критерии, риски, сравнение провайдеров.",
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL; // e.g. "/vps-proxy-research/"
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>
	<body>
		<div class="bg" aria-hidden="true"></div>
		<a class="skip" href="#main">Перейти к содержимому</a>

		<header class="top">
			<div class="shell top__inner">
				<a class="brand" href={baseUrl}>
					<span class="brand__mark" aria-hidden="true">⟡</span>
					<span class="brand__name">vps‑proxy‑research</span>
					<span class="brand__tag">Obsidian → Web</span>
				</a>

				<nav class="nav" aria-label="Навигация">
					<a class="nav__link" href={baseUrl}>Главная</a>
					<a class="nav__link" href={`${baseUrl}tables/`}>Таблицы</a>
					<a class="nav__link" href={`${baseUrl}vps-eu/`}>VPS (EU)</a>
					<a class="nav__link" href={`${baseUrl}proxy-us/`}>Proxy (US)</a>
				</nav>
			</div>
		</header>

		<main id="main" class="shell main">
			<slot />
		</main>

		<footer class="shell foot">
			<div class="foot__left">
				<span class="foot__label">Обновлено:</span>
				<time datetime="2026-04-05">2026‑04‑05</time>
			</div>
			<div class="foot__right">
				<span class="muted">Сайт генерируется статически. Контент — в Markdown.</span>
			</div>
		</footer>
	</body>
</html>
